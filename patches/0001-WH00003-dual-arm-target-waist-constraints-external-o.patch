+#include <iostream>
+#include <string>
+#include <vector>
+
+#include <boost/filesystem.hpp>
+#include <boost/property_tree/info_parser.hpp>
+#include <boost/property_tree/ptree.hpp>
+
+#include <ocs2_core/misc/LoadData.h>
+#include <ocs2_mobile_manipulator/FactoryFunctions.h>
+#include <ocs2_mobile_manipulator/ManipulatorModelInfo.h>
+
+namespace {
+
+struct Args {
+  std::string taskFile;
+  std::string urdfFile;
+};
+
+void printUsage(const char* program) {
+  std::cerr << "Usage: " << program << " --task <task.info> --urdf <robot.urdf>\n";
+}
+
+Args parseArgs(int argc, char** argv) {
+  Args args;
+  for (int i = 1; i < argc; ++i) {
+    const std::string key = argv[i];
+    if ((key == "--task" || key == "-t") && i + 1 < argc) {
+      args.taskFile = argv[++i];
+    } else if ((key == "--urdf" || key == "-u") && i + 1 < argc) {
+      args.urdfFile = argv[++i];
+    } else if (key == "--help" || key == "-h") {
+      printUsage(argv[0]);
+      std::exit(0);
+    } else {
+      std::cerr << "Unknown/invalid argument: " << key << "\n";
+      printUsage(argv[0]);
+      std::exit(1);
+    }
+  }
+  return args;
+}
+
+std::string modelTypeToString(ocs2::mobile_manipulator::ManipulatorModelType type) {
+  using ocs2::mobile_manipulator::ManipulatorModelType;
+  switch (type) {
+    case ManipulatorModelType::DefaultManipulator:
+      return "DefaultManipulator";
+    case ManipulatorModelType::WheelBasedMobileManipulator:
+      return "WheelBasedMobileManipulator";
+    case ManipulatorModelType::FloatingArmManipulator:
+      return "FloatingArmManipulator";
+    case ManipulatorModelType::FullyActuatedFloatingArmManipulator:
+      return "FullyActuatedFloatingArmManipulator";
+    default:
+      return "Unknown";
+  }
+}
+
+void printStateLayout(const ocs2::mobile_manipulator::ManipulatorModelInfo& info) {
+  using ocs2::mobile_manipulator::ManipulatorModelType;
+  const int baseStateDim = static_cast<int>(info.stateDim - info.armDim);
+
+  std::cout << "\n== State layout (observation.state) ==\n";
+  std::cout << "stateDim=" << info.stateDim << ", armDim=" << info.armDim << ", baseStateDim=" << baseStateDim << "\n";
+
+  switch (info.manipulatorModelType) {
+    case ManipulatorModelType::DefaultManipulator: {
+      std::cout << "Base: (implicit identity pose; no base states)\n";
+      break;
+    }
+    case ManipulatorModelType::WheelBasedMobileManipulator: {
+      std::cout << "[0] base_x (world)\n";
+      std::cout << "[1] base_y (world)\n";
+      std::cout << "[2] base_yaw (world)\n";
+      break;
+    }
+    case ManipulatorModelType::FloatingArmManipulator:
+    case ManipulatorModelType::FullyActuatedFloatingArmManipulator: {
+      std::cout << "[0] base_x (world)\n";
+      std::cout << "[1] base_y (world)\n";
+      std::cout << "[2] base_z (world)\n";
+      std::cout << "[3] base_euler_z (ZYX)\n";
+      std::cout << "[4] base_euler_y (ZYX)\n";
+      std::cout << "[5] base_euler_x (ZYX)\n";
+      break;
+    }
+    default:
+      break;
+  }
+
+  std::cout << "Arm joint positions (tail):\n";
+  for (size_t i = 0; i < info.armDim; ++i) {
+    const size_t idx = static_cast<size_t>(baseStateDim) + i;
+    const auto& name = info.dofNames.at(i);
+    std::cout << "[" << idx << "] q_" << name << "\n";
+  }
+}
+
+void printInputLayout(const ocs2::mobile_manipulator::ManipulatorModelInfo& info) {
+  using ocs2::mobile_manipulator::ManipulatorModelType;
+
+  std::cout << "\n== Input layout (observation.input / policy.u) ==\n";
+  std::cout << "inputDim=" << info.inputDim << "\n";
+
+  switch (info.manipulatorModelType) {
+    case ManipulatorModelType::DefaultManipulator: {
+      std::cout << "input is time-derivative of state: u == d/dt(state)\n";
+      break;
+    }
+    case ManipulatorModelType::FullyActuatedFloatingArmManipulator: {
+      std::cout << "input is time-derivative of state: u == d/dt(state)\n";
+      break;
+    }
+    case ManipulatorModelType::FloatingArmManipulator: {
+      std::cout << "Base is unactuated; input drives only arm joint velocities:\n";
+      for (size_t i = 0; i < info.armDim; ++i) {
+        const auto& name = info.dofNames.at(i);
+        std::cout << "[" << i << "] dq_" << name << "\n";
+      }
+      return;
+    }
+    case ManipulatorModelType::WheelBasedMobileManipulator: {
+      std::cout << "[0] base_v (forward velocity in base frame)\n";
+      std::cout << "[1] base_omega (yaw rate)\n";
+      for (size_t i = 0; i < info.armDim; ++i) {
+        const auto& name = info.dofNames.at(i);
+        std::cout << "[" << (2 + i) << "] dq_" << name << "\n";
+      }
+      return;
+    }
+    default:
+      break;
+  }
+
+  // Default/FullyActuated: same ordering as state.
+  const int baseStateDim = static_cast<int>(info.stateDim - info.armDim);
+  const size_t baseDim = static_cast<size_t>(baseStateDim);
+
+  std::cout << "Base part (same order as state base)\n";
+  for (size_t i = 0; i < baseDim; ++i) {
+    std::cout << "[" << i << "] d(base_state[" << i << "])\n";
+  }
+  std::cout << "Arm part (same dofNames order)\n";
+  for (size_t i = 0; i < info.armDim; ++i) {
+    const auto& name = info.dofNames.at(i);
+    const size_t idx = baseDim + i;
+    std::cout << "[" << idx << "] dq_" << name << "\n";
+  }
+}
+
+}  // namespace
+
+int main(int argc, char** argv) {
+  const auto args = parseArgs(argc, argv);
+  if (args.taskFile.empty() || args.urdfFile.empty()) {
+    printUsage(argv[0]);
+    return 1;
+  }
+
+  if (!boost::filesystem::exists(args.taskFile)) {
+    std::cerr << "Task file not found: " << args.taskFile << "\n";
+    return 2;
+  }
+  if (!boost::filesystem::exists(args.urdfFile)) {
+    std::cerr << "URDF file not found: " << args.urdfFile << "\n";
+    return 3;
+  }
+
+  boost::property_tree::ptree pt;
+  boost::property_tree::read_info(args.taskFile, pt);
+
+  const auto modelType = ocs2::mobile_manipulator::loadManipulatorType(args.taskFile, "model_information.manipulatorModelType");
+
+  std::vector<std::string> removeJointNames;
+  ocs2::loadData::loadStdVector<std::string>(args.taskFile, "model_information.removeJoints", removeJointNames, false);
+
+  std::string baseFrame;
+  std::string eeFrame;
+  ocs2::loadData::loadPtreeValue<std::string>(pt, baseFrame, "model_information.baseFrame", false);
+  ocs2::loadData::loadPtreeValue<std::string>(pt, eeFrame, "model_information.eeFrame", false);
+
+  std::cout << "Model type: " << static_cast<int>(modelType) << " (" << modelTypeToString(modelType) << ")\n";
+  std::cout << "baseFrame: \"" << baseFrame << "\"\n";
+  std::cout << "eeFrame: \"" << eeFrame << "\"\n";
+  std::cout << "removeJoints: [";
+  for (size_t i = 0; i < removeJointNames.size(); ++i) {
+    std::cout << (i == 0 ? "" : ", ") << removeJointNames[i];
+  }
+  std::cout << "]\n";
+
+  const auto pinocchioInterface = ocs2::mobile_manipulator::createPinocchioInterface(args.urdfFile, modelType, removeJointNames);
+  const auto modelInfo = ocs2::mobile_manipulator::createManipulatorModelInfo(pinocchioInterface, modelType, baseFrame, eeFrame);
+
+  std::cout << "\n== ManipulatorModelInfo ==\n";
+  std::cout << "stateDim=" << modelInfo.stateDim << ", inputDim=" << modelInfo.inputDim << ", armDim=" << modelInfo.armDim << "\n";
+  std::cout << "dofNames (arm actuated DOFs, order matters):\n";
+  for (size_t i = 0; i < modelInfo.dofNames.size(); ++i) {
+    std::cout << "  [" << i << "] " << modelInfo.dofNames[i] << "\n";
+  }
+
+  printStateLayout(modelInfo);
+  printInputLayout(modelInfo);
+
+  return 0;
+}
