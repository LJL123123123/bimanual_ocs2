--- a/ocs2_pinocchio/ocs2_self_collision/src/PinocchioGeometryInterface.cpp
+++ b/ocs2_pinocchio/ocs2_self_collision/src/PinocchioGeometryInterface.cpp
@@ -37,11 +37,44 @@ OF THIS SOFTWARE, EVEN IF ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.
 #include <pinocchio/multibody/geometry.hpp>
 #include <pinocchio/multibody/model.hpp>
 #include <pinocchio/parsers/urdf.hpp>
+#include <pinocchio/utils/file-explorer.hpp>
+
+#include <algorithm>
+#include <fstream>
 
 #include <urdf_parser/urdf_parser.h>
 
 namespace ocs2 {
 
+namespace {
+std::vector<std::string> getPinocchioPackageDirsFromRosPackagePath() {
+  auto rosPaths = pinocchio::rosPaths();
+  std::vector<std::string> packageDirs;
+  packageDirs.reserve(rosPaths.size() * 2);
+
+  for (auto& path : rosPaths) {
+    if (path.empty()) {
+      continue;
+    }
+
+    packageDirs.push_back(path);
+
+    const std::string packageXmlPath = path + "/package.xml";
+    std::ifstream packageXml(packageXmlPath);
+    if (packageXml.good()) {
+      const auto lastSlash = path.find_last_of('/');
+      if (lastSlash != std::string::npos && lastSlash > 0) {
+        packageDirs.push_back(path.substr(0, lastSlash));
+      }
+    }
+  }
+
+  std::sort(packageDirs.begin(), packageDirs.end());
+  packageDirs.erase(std::unique(packageDirs.begin(), packageDirs.end()), packageDirs.end());
+  return packageDirs;
+}
+}  // namespace
+
