+  bool enableDualEeTarget_ = false;
+  bool hasObservation_ = false;
+
+  geometry_msgs::Pose rightPose_;
+  geometry_msgs::Pose leftPose_;
+
+  SystemObservation latestObservation_;
+
+  ros::Subscriber observationSubscriber_;
+
