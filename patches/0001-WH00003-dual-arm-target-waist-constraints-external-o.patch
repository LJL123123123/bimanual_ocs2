+class DualEeTargetNode {
+ public:
+  DualEeTargetNode(ros::NodeHandle& nodeHandle, const std::string& robotName)
+      : nodeHandle_(nodeHandle),
+        robotName_(robotName),
+        interactiveMarkerServer_(std::make_unique<interactive_markers::InteractiveMarkerServer>("simple_marker")),
+        targetTrajectoriesPublisher_(nodeHandle_, robotName_) {
+    std::string taskFile;
+    if (!nodeHandle_.getParam("/taskFile", taskFile)) {
+      throw std::runtime_error("[MobileManipulatorTarget] Could not read /taskFile from parameter server.");
+    }
+
+    boost::property_tree::ptree pt;
+    boost::property_tree::read_info(taskFile, pt);
+
+    loadData::loadPtreeValue(pt, enableDualEeTarget_, "model_information.enableDualEeTarget", true);
+
+    rightPose_ = makeDefaultPose(0.5, -0.2, 0.6);
+    leftPose_ = makeDefaultPose(0.5, 0.2, 0.6);
+
+    createMarkers();
+    interactiveMarkerServer_->applyChanges();
+
+    observationSubscriber_ = nodeHandle_.subscribe("/" + robotName_ + "_mpc_observation", 1,
+                                                   &DualEeTargetNode::observationCallback, this);
+
+    ROS_INFO_STREAM("[MobileManipulatorTarget] enableDualEeTarget = " << std::boolalpha << enableDualEeTarget_);
+  }
+
+ private:
+  void createMarkers() {
+    auto rightMarker = make6DofMarker("world", "right_ee_target", rightPose_);
+    interactiveMarkerServer_->insert(
+        rightMarker, boost::bind(&DualEeTargetNode::processRightFeedback, this, _1));
+
+    if (enableDualEeTarget_) {
+      auto leftMarker = make6DofMarker("world", "left_ee_target", leftPose_);
+      interactiveMarkerServer_->insert(
+          leftMarker, boost::bind(&DualEeTargetNode::processLeftFeedback, this, _1));
+    }
+  }
+
+  void processRightFeedback(const visualization_msgs::InteractiveMarkerFeedbackConstPtr& feedback) {
+    if (feedback->event_type == visualization_msgs::InteractiveMarkerFeedback::POSE_UPDATE) {
+      rightPose_ = feedback->pose;
+      publishTargetTrajectories();
+    }
+  }
+
+  void processLeftFeedback(const visualization_msgs::InteractiveMarkerFeedbackConstPtr& feedback) {
+    if (feedback->event_type == visualization_msgs::InteractiveMarkerFeedback::POSE_UPDATE) {
+      leftPose_ = feedback->pose;
+      publishTargetTrajectories();
+    }
+  }
+
+  void observationCallback(const ocs2_msgs::mpc_observation::ConstPtr& msg) {
+    latestObservation_.time = msg->time;
+    latestObservation_.state = Eigen::Map<const Eigen::Matrix<float, Eigen::Dynamic, 1>>(msg->state.value.data(), msg->state.value.size())
+                                  .template cast<scalar_t>();
+    latestObservation_.input = Eigen::Map<const Eigen::Matrix<float, Eigen::Dynamic, 1>>(msg->input.value.data(), msg->input.value.size())
+                                  .template cast<scalar_t>();
+
+    // Publish once when first observation arrives, so OCP has a valid target immediately.
+    if (!hasObservation_) {
+      hasObservation_ = true;
+      publishTargetTrajectories();
+    }
+  }
+
+  TargetTrajectories buildSingleTarget() const {
+    const scalar_array_t timeTrajectory{latestObservation_.time};
+
+    Eigen::Vector3d position(rightPose_.position.x, rightPose_.position.y, rightPose_.position.z);
+    Eigen::Quaterniond orientation(rightPose_.orientation.w, rightPose_.orientation.x,
+                                   rightPose_.orientation.y, rightPose_.orientation.z);
+    orientation.normalize();
+
+    const vector_t target = (vector_t(7) << position, orientation.coeffs()).finished();
+    const vector_array_t stateTrajectory{target};
+    const vector_array_t inputTrajectory{vector_t::Zero(latestObservation_.input.size())};
+
+    return {timeTrajectory, stateTrajectory, inputTrajectory};
+  }
+
+  TargetTrajectories buildDualTarget() const {
+    const scalar_array_t timeTrajectory{latestObservation_.time};
+
+    Eigen::Vector3d rightPosition(rightPose_.position.x, rightPose_.position.y, rightPose_.position.z);
+    Eigen::Quaterniond rightOrientation(rightPose_.orientation.w, rightPose_.orientation.x,
+                                        rightPose_.orientation.y, rightPose_.orientation.z);
+    rightOrientation.normalize();
+
+    Eigen::Vector3d leftPosition(leftPose_.position.x, leftPose_.position.y, leftPose_.position.z);
+    Eigen::Quaterniond leftOrientation(leftPose_.orientation.w, leftPose_.orientation.x,
+                                       leftPose_.orientation.y, leftPose_.orientation.z);
+    leftOrientation.normalize();
+
+    vector_t target(14);
+    target << rightPosition, rightOrientation.coeffs(), leftPosition, leftOrientation.coeffs();
+
+    const vector_array_t stateTrajectory{target};
+    const vector_array_t inputTrajectory{vector_t::Zero(latestObservation_.input.size())};
+
+    return {timeTrajectory, stateTrajectory, inputTrajectory};
+  }
+
+  void publishTargetTrajectories() {
+    if (!hasObservation_) {
+      return;
+    }
+
+    const auto targetTrajectories = enableDualEeTarget_ ? buildDualTarget() : buildSingleTarget();
+    targetTrajectoriesPublisher_.publishTargetTrajectories(targetTrajectories);
+  }
