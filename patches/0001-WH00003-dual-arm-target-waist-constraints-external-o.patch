@@ -0,0 +1,43 @@
+#pragma once
+
+#include <ocs2_core/penalties/Penalties.h>
+
+namespace ocs2 {
+namespace mobile_manipulator {
+
+class OneSidedQuadraticPenalty final : public PenaltyBase {
+ public:
+  explicit OneSidedQuadraticPenalty(scalar_t mu) : mu_(mu) {}
+  ~OneSidedQuadraticPenalty() override = default;
+
+  OneSidedQuadraticPenalty* clone() const override { return new OneSidedQuadraticPenalty(*this); }
+
+  std::string name() const override { return "OneSidedQuadraticPenalty"; }
+
+  scalar_t getValue(scalar_t t, scalar_t h) const override {
+    if (h <= 0.0) {
+      return 0.0;
+    }
+    return 0.5 * mu_ * h * h;
+  }
+
+  scalar_t getDerivative(scalar_t t, scalar_t h) const override {
+    if (h <= 0.0) {
+      return 0.0;
+    }
+    return mu_ * h;
+  }
+
+  scalar_t getSecondDerivative(scalar_t t, scalar_t h) const override {
+    if (h <= 0.0) {
+      return 0.0;
+    }
+    return mu_;
+  }
+
+ private:
+  scalar_t mu_;
+};
+
+}  // namespace mobile_manipulator
+}  // namespace ocs2
