@@ -0,0 +1,53 @@
+#include <ocs2_mobile_manipulator/MobileManipulatorPreComputation.h>
+#include <ocs2_mobile_manipulator/constraint/LinkVerticalConstraint.h>
+
+namespace ocs2 {
+namespace mobile_manipulator {
+
+LinkVerticalConstraint::LinkVerticalConstraint(const EndEffectorKinematics<scalar_t>& endEffectorKinematics)
+    : StateConstraint(ConstraintOrder::Linear), endEffectorKinematicsPtr_(endEffectorKinematics.clone()) {
+  if (endEffectorKinematics.getIds().size() != 2) {
+    throw std::runtime_error("[LinkVerticalConstraint] Expect exactly 2 frame IDs: root and vertical-tip.");
+  }
+  pinocchioEEKinPtr_ = dynamic_cast<PinocchioEndEffectorKinematics*>(endEffectorKinematicsPtr_.get());
+}
+
+size_t LinkVerticalConstraint::getNumConstraints(scalar_t /*time*/) const {
+  return 2;  // x/y only => roll & pitch upright, yaw free
+}
+
+vector_t LinkVerticalConstraint::getValue(scalar_t /*time*/, const vector_t& state,
+                                          const PreComputation& preComputation) const {
+  if (pinocchioEEKinPtr_ != nullptr) {
+    const auto& preCompMM = cast<MobileManipulatorPreComputation>(preComputation);
+    pinocchioEEKinPtr_->setPinocchioInterface(preCompMM.getPinocchioInterface());
+  }
+
+  const auto positions = endEffectorKinematicsPtr_->getPosition(state);
+  const auto& pRoot = positions[0];
+  const auto& pTip = positions[1];
+
+  vector_t constraint(2);
+  constraint = pTip.head<2>() - pRoot.head<2>();
+  return constraint;
+}
+
+VectorFunctionLinearApproximation LinkVerticalConstraint::getLinearApproximation(
+    scalar_t /*time*/, const vector_t& state, const PreComputation& preComputation) const {
+  if (pinocchioEEKinPtr_ != nullptr) {
+    const auto& preCompMM = cast<MobileManipulatorPreComputation>(preComputation);
+    pinocchioEEKinPtr_->setPinocchioInterface(preCompMM.getPinocchioInterface());
+  }
+
+  const auto positionApprox = endEffectorKinematicsPtr_->getPositionLinearApproximation(state);
+  const auto& pRoot = positionApprox[0];
+  const auto& pTip = positionApprox[1];
+
+  VectorFunctionLinearApproximation approximation(2, state.rows(), 0);
+  approximation.f = pTip.f.head<2>() - pRoot.f.head<2>();
+  approximation.dfdx = pTip.dfdx.topRows(2) - pRoot.dfdx.topRows(2);
+  return approximation;
+}
+
+}  // namespace mobile_manipulator
+}  // namespace ocs2
