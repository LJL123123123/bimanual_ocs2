+  right_tf.transform.translation = ros_msg_helpers::getVectorMsg(rightPos);
+  right_tf.transform.rotation = ros_msg_helpers::getOrientationMsg(rightQuat);
+  tfBroadcaster_.sendTransform(right_tf);
+
