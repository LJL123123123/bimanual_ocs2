 namespace ocs2 {
 
+namespace {
+std::vector<std::string> getPinocchioPackageDirsFromRosPackagePath() {
+  auto rosPaths = pinocchio::rosPaths();
+  std::vector<std::string> packageDirs;
+  packageDirs.reserve(rosPaths.size() * 2);
+
+  for (auto& path : rosPaths) {
+    if (path.empty()) {
+      continue;
+    }
+
+    // Add the path itself (useful when it already points to a search root like /opt/ros/noetic/share)
+    packageDirs.push_back(path);
+
+    // If ROS_PACKAGE_PATH contains a concrete package directory, also add its parent directory.
+    // Pinocchio's URDF parser resolves `package://<pkg>/...` by searching for <pkg> under packageDirs.
+    const std::string packageXmlPath = path + "/package.xml";
+    std::ifstream packageXml(packageXmlPath);
+    if (packageXml.good()) {
+      const auto lastSlash = path.find_last_of('/');
+      if (lastSlash != std::string::npos && lastSlash > 0) {
+        packageDirs.push_back(path.substr(0, lastSlash));
+      }
+    }
+  }
+
+  std::sort(packageDirs.begin(), packageDirs.end());
+  packageDirs.erase(std::unique(packageDirs.begin(), packageDirs.end()), packageDirs.end());
+  return packageDirs;
+}
+}  // namespace
+
 /******************************************************************************************************/
 /******************************************************************************************************/
 /******************************************************************************************************/
@@ -116,7 +152,8 @@ void PinocchioSphereInterface::buildGeomFromPinocchioInterface(const PinocchioIn
   urdfAsXml->Accept(&printer);
   const std::stringstream urdfAsStringStream(printer.Str());
 
-  pinocchio::urdf::buildGeom(pinocchioInterface.getModel(), urdfAsStringStream, pinocchio::COLLISION, geomModel);
+  const auto packageDirs = getPinocchioPackageDirsFromRosPackagePath();
+  pinocchio::urdf::buildGeom(pinocchioInterface.getModel(), urdfAsStringStream, pinocchio::COLLISION, geomModel, packageDirs);
 }
 
