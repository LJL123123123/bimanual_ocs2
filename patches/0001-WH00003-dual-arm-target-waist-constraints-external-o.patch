+#include <stdexcept>
+
+#include <pinocchio/algorithm/center-of-mass.hpp>
+#include <pinocchio/algorithm/frames.hpp>
+#include <pinocchio/algorithm/kinematics.hpp>
+
+#include <ocs2_mobile_manipulator/constraint/ComPolygonConstraint.h>
+
+namespace ocs2 {
+namespace mobile_manipulator {
+
+ComPolygonConstraint::ComPolygonConstraint(const PinocchioInterface& pinocchioInterface,
+                                           const ManipulatorModelInfo& modelInfo,
+                                           const std::string& baseFrame,
+                                           const std::vector<Eigen::Vector2d>& polygonVertices,
+                                           scalar_t finiteDifferenceEps)
+    : StateConstraint(ConstraintOrder::Linear),
+      pinocchioInterface_(pinocchioInterface),
+      modelInfo_(modelInfo),
+      baseFrame_(baseFrame),
+      vertices_(polygonVertices),
+      finiteDifferenceEps_(finiteDifferenceEps) {
+  if (vertices_.size() < 3) {
+    throw std::runtime_error("[ComPolygonConstraint] polygon must have at least 3 vertices.");
+  }
+
+  const auto& model = pinocchioInterface_.getModel();
+  baseFrameId_ = model.getFrameId(baseFrame_);
+  if (baseFrameId_ >= model.frames.size()) {
+    throw std::runtime_error("[ComPolygonConstraint] baseFrame \"" + baseFrame_ + "\" not found in pinocchio frames.");
+  }
+
+  outwardNormals_.reserve(vertices_.size());
+  for (size_t i = 0; i < vertices_.size(); ++i) {
+    const auto& vi = vertices_[i];
+    const auto& vj = vertices_[(i + 1) % vertices_.size()];
+
+    Eigen::Vector2d edge = vj - vi;
+    if (edge.norm() < 1e-10) {
+      throw std::runtime_error("[ComPolygonConstraint] consecutive polygon vertices are identical.");
+    }
+
+    // Assume vertices are ordered CCW.
+    // For CCW polygon, outward normal can be [ey, -ex].
+    Eigen::Vector2d normal(edge.y(), -edge.x());
+    outwardNormals_.push_back(normal);
+  }
+}
+
+size_t ComPolygonConstraint::getNumConstraints(scalar_t /*time*/) const {
+  return vertices_.size();
+}
+
+vector_t ComPolygonConstraint::getValue(scalar_t /*time*/, const vector_t& state,
+                                        const PreComputation& /*preComputation*/) const {
+  return computeConstraint(state);
+}
+
+VectorFunctionLinearApproximation ComPolygonConstraint::getLinearApproximation(
+    scalar_t /*time*/, const vector_t& state, const PreComputation& /*preComputation*/) const {
+  VectorFunctionLinearApproximation approximation(getNumConstraints(0.0), state.size(), 0);
+  approximation.f = computeConstraint(state);
+  approximation.dfdx = finiteDifferenceJacobian(state);
+  return approximation;
+}
+
+vector_t ComPolygonConstraint::computeConstraint(const vector_t& state) const {
+  auto pinocchioInterface = pinocchioInterface_;  // local copy
+  auto& model = pinocchioInterface.getModel();
+  auto& data = pinocchioInterface.getData();
+
+  // In this project, state is used directly as generalized coordinates for the kinematic model.
+  const vector_t q = state;
+
+  pinocchio::forwardKinematics(model, data, q);
+  pinocchio::updateFramePlacements(model, data);
+  pinocchio::centerOfMass(model, data, q);
+
+  const Eigen::Vector3d pComW = data.com[0];
+  const auto& basePlacement = data.oMf[baseFrameId_];
+  const Eigen::Matrix3d R_WB = basePlacement.rotation();
+  const Eigen::Vector3d p_WB = basePlacement.translation();
+
+  const Eigen::Vector3d pComB = R_WB.transpose() * (pComW - p_WB);
+  const Eigen::Vector2d c = pComB.head<2>();
+
+  vector_t g(vertices_.size());
+  for (size_t i = 0; i < vertices_.size(); ++i) {
+    g(i) = outwardNormals_[i].dot(c - vertices_[i]);
+  }
+
+  // Constraint convention:
+  // g_i(x) <= 0 means inside polygon
+  // g_i(x) > 0 means outside edge i
+  return g;
+}
+
+matrix_t ComPolygonConstraint::finiteDifferenceJacobian(const vector_t& state) const {
+  const size_t m = vertices_.size();
+  const size_t n = state.size();
+
+  matrix_t J = matrix_t::Zero(m, n);
+
+  for (size_t j = 0; j < n; ++j) {
+    vector_t xPlus = state;
+    vector_t xMinus = state;
+    xPlus(j) += finiteDifferenceEps_;
+    xMinus(j) -= finiteDifferenceEps_;
+
+    const vector_t fPlus = computeConstraint(xPlus);
+    const vector_t fMinus = computeConstraint(xMinus);
+
+    J.col(j) = (fPlus - fMinus) / (2.0 * finiteDifferenceEps_);
+  }
+
+  return J;
+}
+
+}  // namespace mobile_manipulator
+}  // namespace ocs2
