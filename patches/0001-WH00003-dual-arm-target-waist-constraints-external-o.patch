+// 新增com多边形约束
+std::unique_ptr<StateCost> MobileManipulatorInterface::getComPolygonConstraint(
+    const PinocchioInterface& pinocchioInterface,
+    const std::string& taskFile,
+    const std::string& prefix) {
+  boost::property_tree::ptree pt;
+  boost::property_tree::read_info(taskFile, pt);
+
+  // 按你的需求，polygon 一律相对 model_information.baseFrame 定义
+  const std::string polygonFrame = manipulatorModelInfo_.baseFrame;
+
+  int numVertices = 0;
+  loadData::loadPtreeValue(pt, numVertices, prefix + ".numVertices", false);
+
+  if (numVertices <= 0) {
+    throw std::runtime_error("[getComPolygonConstraint] numVertices must be > 0.");
+  }
+
+  matrix_t vertexOffsets = matrix_t::Zero(numVertices, 2);
+  loadData::loadEigenMatrix(taskFile, prefix + ".vertices", vertexOffsets);
+
+  if (vertexOffsets.rows() != numVertices || vertexOffsets.cols() != 2) {
+    throw std::runtime_error("[getComPolygonConstraint] vertices must be numVertices x 2.");
+  }
+
+  std::vector<Eigen::Vector2d> vertices(numVertices);
+  for (int i = 0; i < numVertices; ++i) {
+    vertices[i] = vertexOffsets.row(i).transpose();
+  }
+
+  scalar_t mu = 50.0;
+  scalar_t finiteDifferenceEps = 1e-6;
+
+  std::cerr << "\n #### " << prefix << " Settings: ";
+  std::cerr << "\n #### =============================================================================\n";
+  loadData::loadPtreeValue(pt, mu, prefix + ".mu", true);
+  loadData::loadPtreeValue(pt, finiteDifferenceEps, prefix + ".finiteDifferenceEps", true);
+  std::cerr << " #### frame: " << polygonFrame << "\n";
+  std::cerr << " #### numVertices: " << numVertices << "\n";
+  std::cerr << " #### mu: " << mu << "\n";
+  std::cerr << " #### finiteDifferenceEps: " << finiteDifferenceEps << "\n";
+  std::cerr << " #### =============================================================================\n";
+
+  auto constraint = std::make_unique<ComPolygonConstraint>(
+      pinocchioInterface, manipulatorModelInfo_, polygonFrame, vertices, finiteDifferenceEps);
+
+  std::vector<std::unique_ptr<PenaltyBase>> penaltyArray(numVertices);
+  for (int i = 0; i < numVertices; ++i) {
+    penaltyArray[i] = std::make_unique<OneSidedQuadraticPenalty>(mu);
+  }
+
+  return std::make_unique<StateSoftConstraint>(std::move(constraint), std::move(penaltyArray));
+}
