diff --git a/ocs2_robotic_examples/ocs2_mobile_manipulator_ros/scripts/vr_ar_target_to_mpc_target.py b/ocs2_robotic_examples/ocs2_mobile_manipulator_ros/scripts/vr_ar_target_to_mpc_target.py
