+geometry_msgs::msg::Pose makeDefaultPose(double x, double y, double z) {
+  geometry_msgs::msg::Pose pose;
+  pose.position.x = x;
+  pose.position.y = y;
+  pose.position.z = z;
+  pose.orientation.w = 1.0;
+  pose.orientation.x = 0.0;
+  pose.orientation.y = 0.0;
+  pose.orientation.z = 0.0;
+  return pose;
+}
+
+visualization_msgs::msg::Marker makeSphereMarker() {
+  visualization_msgs::msg::Marker marker;
+  marker.type = visualization_msgs::msg::Marker::SPHERE;
+  marker.scale.x = 0.08;
+  marker.scale.y = 0.08;
+  marker.scale.z = 0.08;
+  marker.color.r = 0.1;
+  marker.color.g = 0.8;
+  marker.color.b = 0.2;
+  marker.color.a = 0.9;
+  return marker;
+}
+
+visualization_msgs::msg::InteractiveMarkerControl makeMoveRotateControl(
+    const geometry_msgs::msg::Quaternion& orientation, const std::string& name,
+    int interactionMode) {
+  visualization_msgs::msg::InteractiveMarkerControl control;
+  control.orientation = orientation;
+  control.name = name;
+  control.interaction_mode = interactionMode;
+  return control;
 }
 
+visualization_msgs::msg::InteractiveMarker make6DofMarker(
+    const std::string& frameId, const std::string& markerName,
+    const geometry_msgs::msg::Pose& pose) {
+  visualization_msgs::msg::InteractiveMarker intMarker;
+  intMarker.header.frame_id = frameId;
+  intMarker.name = markerName;
+  intMarker.description = markerName;
+  intMarker.scale = 0.25;
+  intMarker.pose = pose;
+
+  // Visual marker
+  visualization_msgs::msg::InteractiveMarkerControl visualControl;
+  visualControl.always_visible = true;
+  visualControl.markers.push_back(makeSphereMarker());
+  intMarker.controls.push_back(visualControl);
+
+  geometry_msgs::msg::Quaternion qx;
+  qx.w = 1.0;
+  qx.x = 1.0;
+  qx.y = 0.0;
+  qx.z = 0.0;
+
+  geometry_msgs::msg::Quaternion qy;
+  qy.w = 1.0;
+  qy.x = 0.0;
+  qy.y = 1.0;
+  qy.z = 0.0;
+
+  geometry_msgs::msg::Quaternion qz;
+  qz.w = 1.0;
+  qz.x = 0.0;
+  qz.y = 0.0;
+  qz.z = 1.0;
+
+  intMarker.controls.push_back(makeMoveRotateControl(
+      qx, "rotate_x",
+      visualization_msgs::msg::InteractiveMarkerControl::ROTATE_AXIS));
+  intMarker.controls.push_back(makeMoveRotateControl(
+      qx, "move_x", visualization_msgs::msg::InteractiveMarkerControl::MOVE_AXIS));
+  intMarker.controls.push_back(makeMoveRotateControl(
+      qy, "rotate_y",
+      visualization_msgs::msg::InteractiveMarkerControl::ROTATE_AXIS));
+  intMarker.controls.push_back(makeMoveRotateControl(
+      qy, "move_y", visualization_msgs::msg::InteractiveMarkerControl::MOVE_AXIS));
+  intMarker.controls.push_back(makeMoveRotateControl(
+      qz, "rotate_z",
+      visualization_msgs::msg::InteractiveMarkerControl::ROTATE_AXIS));
+  intMarker.controls.push_back(makeMoveRotateControl(
+      qz, "move_z", visualization_msgs::msg::InteractiveMarkerControl::MOVE_AXIS));
+
+  return intMarker;
+}
