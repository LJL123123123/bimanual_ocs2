index 0000000000000000000000000000000000000000..3c9c4449550735a85c5021f8d41a619d6f83111c
--- /dev/null
+++ b/ocs2_robotic_examples/ocs2_mobile_manipulator_ros/scripts/vr_ar_target_to_mpc_target.py
@@ -0,0 +1,147 @@
+#!/usr/bin/env python3
+
+import math
+from dataclasses import dataclass
+from typing import Optional, Tuple
+
+import rospy
+from geometry_msgs.msg import PoseStamped
+
+from ocs2_msgs.msg import mpc_input, mpc_observation, mpc_state, mpc_target_trajectories
+
+
+def _normalize_quaternion(x: float, y: float, z: float, w: float) -> Tuple[float, float, float, float]:
+    norm = math.sqrt(x * x + y * y + z * z + w * w)
+    if norm <= 0.0:
+        return 0.0, 0.0, 0.0, 1.0
+    return x / norm, y / norm, z / norm, w / norm
+
+
+@dataclass
+class _ObservationCache:
+    time: float = 0.0
+    input_dim: int = 0
+    has_observation: bool = False
+
+
+class VRTTargetToMpcTargetNode:
+    def __init__(self) -> None:
+        self._robot_name = rospy.get_param("~robot_name", "mobile_manipulator")
+        self._dual_target = bool(rospy.get_param("~dual_target", False))
+
+        self._right_topic = rospy.get_param("~right_pose_topic", "/vr/right_ee_target")
+        self._left_topic = rospy.get_param("~left_pose_topic", "/vr/left_ee_target")
+
+        self._right_pose: PoseStamped = PoseStamped()
+        self._left_pose: PoseStamped = PoseStamped()
+        self._has_right_pose = False
+        self._has_left_pose = False
+
+        self._obs = _ObservationCache()
+
+        self._target_pub = rospy.Publisher(
+            f"/{self._robot_name}_mpc_target", mpc_target_trajectories, queue_size=1
+        )
+        self._obs_sub = rospy.Subscriber(
+            f"/{self._robot_name}_mpc_observation", mpc_observation, self._on_observation, queue_size=1
+        )
+        self._right_sub = rospy.Subscriber(self._right_topic, PoseStamped, self._on_right_pose, queue_size=1)
+        self._left_sub = None
+        if self._dual_target:
+            self._left_sub = rospy.Subscriber(self._left_topic, PoseStamped, self._on_left_pose, queue_size=1)
+
+        rospy.loginfo(
+            "[vr_ar_target_to_mpc_target] robot_name=%s dual_target=%s right_topic=%s left_topic=%s",
+            self._robot_name,
+            self._dual_target,
+            self._right_topic,
+            self._left_topic,
+        )
+
+    def _on_observation(self, msg: mpc_observation) -> None:
+        self._obs.time = float(msg.time)
+        self._obs.input_dim = len(msg.input.value)
+        if not self._obs.has_observation:
+            self._obs.has_observation = True
+            self._publish_if_ready(force=True)
+
+    def _on_right_pose(self, msg: PoseStamped) -> None:
+        self._right_pose = msg
+        self._has_right_pose = True
+        self._publish_if_ready(force=False)
+
+    def _on_left_pose(self, msg: PoseStamped) -> None:
+        self._left_pose = msg
+        self._has_left_pose = True
+        self._publish_if_ready(force=False)
+
+    def _build_target_vector(self) -> Optional[list]:
+        if not self._has_right_pose:
+            return None
+
+        rp = self._right_pose.pose.position
+        rq = self._right_pose.pose.orientation
+        rqx, rqy, rqz, rqw = _normalize_quaternion(rq.x, rq.y, rq.z, rq.w)
+
+        if not self._dual_target:
+            # OCS2 expects: position(3) + quaternion.coeffs()(4) == (x,y,z,w)
+            return [float(rp.x), float(rp.y), float(rp.z), float(rqx), float(rqy), float(rqz), float(rqw)]
+
+        if not self._has_left_pose:
+            return None
+
+        lp = self._left_pose.pose.position
+        lq = self._left_pose.pose.orientation
+        lqx, lqy, lqz, lqw = _normalize_quaternion(lq.x, lq.y, lq.z, lq.w)
+
+        return [
+            float(rp.x),
+            float(rp.y),
+            float(rp.z),
+            float(rqx),
+            float(rqy),
+            float(rqz),
+            float(rqw),
+            float(lp.x),
+            float(lp.y),
+            float(lp.z),
+            float(lqx),
+            float(lqy),
+            float(lqz),
+            float(lqw),
+        ]
+
+    def _publish_if_ready(self, force: bool) -> None:
+        if not self._obs.has_observation:
+            return
+
+        target_vec = self._build_target_vector()
+        if target_vec is None:
+            return
+
+        msg = mpc_target_trajectories()
+        msg.timeTrajectory = [self._obs.time]
+
+        state = mpc_state()
+        state.value = [float(v) for v in target_vec]
+        msg.stateTrajectory = [state]
+
+        inp = mpc_input()
+        inp.value = [0.0] * int(self._obs.input_dim)
+        msg.inputTrajectory = [inp]
+
+        # Publish on every update; no latching here.
+        self._target_pub.publish(msg)
+
+        if force:
+            rospy.loginfo("[vr_ar_target_to_mpc_target] First target published (dim=%d)", len(target_vec))
+
+
+def main() -> None:
+    rospy.init_node("vr_ar_target_to_mpc_target", anonymous=False)
+    _ = VRTTargetToMpcTargetNode()
+    rospy.spin()
+
+
+if __name__ == "__main__":
+    main()
