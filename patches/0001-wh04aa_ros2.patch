+//新增link约束
+std::unique_ptr<StateCost> MobileManipulatorInterface::getWaistRollPitchConstraint(
+    const PinocchioInterface& pinocchioInterface, const std::string& taskFile, const std::string& prefix,
+    bool usePreComputation, const std::string& libraryFolder, bool recompileLibraries) {
+  scalar_t muRoll = 10.0;
+  scalar_t muPitch = 10.0;
+
+  boost::property_tree::ptree pt;
+  boost::property_tree::read_info(taskFile, pt);
+
+  std::cerr << "\n #### " << prefix << " Settings: ";
+  std::cerr << "\n #### =============================================================================\n";
+  loadData::loadPtreeValue(pt, muRoll, prefix + ".muRoll", true);
+  loadData::loadPtreeValue(pt, muPitch, prefix + ".muPitch", true);
+  std::cerr << " #### =============================================================================\n";
+
+  const std::string rootFrame = "waist_yaw_link";
+  const std::string tipFrame = "waist_yaw_upright_link";
+
+  std::unique_ptr<StateConstraint> constraint;
+  if (usePreComputation) {
+    MobileManipulatorPinocchioMapping pinocchioMapping(manipulatorModelInfo_);
+    PinocchioEndEffectorKinematics frameKinematics(pinocchioInterface, pinocchioMapping, {rootFrame, tipFrame});
+    constraint.reset(new LinkVerticalConstraint(frameKinematics));
+  } else {
+    MobileManipulatorPinocchioMappingCppAd pinocchioMappingCppAd(manipulatorModelInfo_);
+    PinocchioEndEffectorKinematicsCppAd frameKinematics(pinocchioInterface, pinocchioMappingCppAd, {rootFrame, tipFrame},
+                                                        manipulatorModelInfo_.stateDim, manipulatorModelInfo_.inputDim,
+                                                        "waist_vertical_kinematics", libraryFolder, recompileLibraries, false);
+    constraint.reset(new LinkVerticalConstraint(frameKinematics));
+  }
+
+  std::vector<std::unique_ptr<PenaltyBase>> penaltyArray(2);
+  penaltyArray[0] = std::make_unique<QuadraticPenalty>(muRoll);   // 对应 x
+  penaltyArray[1] = std::make_unique<QuadraticPenalty>(muPitch);  // 对应 y
+
+  return std::make_unique<StateSoftConstraint>(std::move(constraint), std::move(penaltyArray));
+}
