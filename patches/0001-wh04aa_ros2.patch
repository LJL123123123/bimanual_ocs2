+  markerArray.markers.resize(2);
+
+  // --- CoM marker ---
+  auto& comMarker = markerArray.markers[0];
+  comMarker.header.stamp = timeStamp;
+  comMarker.header.frame_id = "world";
+  comMarker.ns = "com_support";
+  comMarker.id = 0;
+  comMarker.type = visualization_msgs::msg::Marker::SPHERE;
+  comMarker.action = visualization_msgs::msg::Marker::ADD;
+  comMarker.pose.orientation.w = 1.0;
+  comMarker.scale.x = 0.06;
+  comMarker.scale.y = 0.06;
+  comMarker.scale.z = 0.06;
+  comMarker.color.r = 0.9f;
+  comMarker.color.g = 0.1f;
+  comMarker.color.b = 0.1f;
+  comMarker.color.a = 0.9f;
+
+  // --- Support polygon marker ---
+  auto& polyMarker = markerArray.markers[1];
+  polyMarker.header.stamp = timeStamp;
+  polyMarker.header.frame_id = "world";
+  polyMarker.ns = "com_support";
+  polyMarker.id = 1;
+  polyMarker.type = visualization_msgs::msg::Marker::LINE_STRIP;
+  polyMarker.action = visualization_msgs::msg::Marker::ADD;
+  polyMarker.pose.orientation.w = 1.0;
+  polyMarker.scale.x = 0.01;  // line width
+  polyMarker.color.r = 0.1f;
+  polyMarker.color.g = 0.9f;
+  polyMarker.color.b = 0.1f;
+  polyMarker.color.a = 0.9f;
+
+  // Compute CoM using Pinocchio when possible.
+  try {
+    const auto& model = pinocchioInterface_.getModel();
+    if (static_cast<size_t>(observation.state.size()) == model.nq) {
+      const vector_t q = observation.state;
+      auto& data = pinocchioInterface_.getData();
+      pinocchio::forwardKinematics(model, data, q);
+      pinocchio::updateFramePlacements(model, data);
+      pinocchio::centerOfMass(model, data, q);
+      const Eigen::Vector3d pComW = data.com[0];
+      comMarker.pose.position.x = pComW.x();
+      comMarker.pose.position.y = pComW.y();
+      comMarker.pose.position.z = pComW.z();
+    } else {
+      // Fallback: place marker at base position (still gives user a visual reference)
+      comMarker.pose.position.x = r_world_base.x();
+      comMarker.pose.position.y = r_world_base.y();
+      comMarker.pose.position.z = r_world_base.z();
+    }
+  } catch (const std::exception& e) {
+    comMarker.pose.position.x = r_world_base.x();
+    comMarker.pose.position.y = r_world_base.y();
+    comMarker.pose.position.z = r_world_base.z();
+    RCLCPP_WARN_STREAM_THROTTLE(node_->get_logger(), *node_->get_clock(), 2000,
+                                "[MobileManipulatorDummyVisualization] CoM computation failed: "
+                                    << e.what());
+  }
+
+  if (comPolygonActive_ && comPolygonVertices_.size() >= 3) {
+    polyMarker.points.reserve(comPolygonVertices_.size() + 1);
+    for (const auto& v : comPolygonVertices_) {
+      const Eigen::Vector3d p_base(v.x(), v.y(), 0.0);
+      const Eigen::Vector3d p_world = r_world_base + R_world_base * p_base;
+      geometry_msgs::msg::Point p;
+      p.x = p_world.x();
+      p.y = p_world.y();
+      p.z = p_world.z();
+      polyMarker.points.push_back(p);
+    }
+    // close polygon
+    geometry_msgs::msg::Point p0 = polyMarker.points.front();
+    polyMarker.points.push_back(p0);
+  } else {
+    // If polygon disabled/missing, hide the marker
+    polyMarker.action = visualization_msgs::msg::Marker::DELETE;
+  }
+
+  comPolygonPublisher_->publish(markerArray);
+}
