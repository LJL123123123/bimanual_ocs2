+class DualEeTargetNode {
+ public:
+  DualEeTargetNode(const rclcpp::Node::SharedPtr& node,
+                   const std::string& robotName)
+      : node_(node),
+        robotName_(robotName),
+        interactiveMarkerServer_("simple_marker", node_),
+        targetTrajectoriesPublisher_(node_, robotName_) {
+    const std::string taskFile = node_->declare_parameter<std::string>("taskFile", "");
+    if (taskFile.empty()) {
+      RCLCPP_ERROR(node_->get_logger(),
+                   "[MobileManipulatorTarget] Parameter 'taskFile' is empty. "
+                   "Falling back to enableDualEeTarget=false.");
+      enableDualEeTarget_ = false;
+    } else {
+      boost::property_tree::ptree pt;
+      boost::property_tree::read_info(taskFile, pt);
+      loadData::loadPtreeValue(pt, enableDualEeTarget_,
+                               "model_information.enableDualEeTarget", true);
+    }
+
+    rightPose_ = makeDefaultPose(0.5, -0.2, 0.6);
+    leftPose_ = makeDefaultPose(0.5, 0.2, 0.6);
+
+    createMarkers();
+    interactiveMarkerServer_.applyChanges();
+
+    observationSubscriber_ =
+        node_->create_subscription<ocs2_msgs::msg::MpcObservation>(
+            robotName_ + "_mpc_observation", 1,
+            std::bind(&DualEeTargetNode::observationCallback, this,
+                      std::placeholders::_1));
+
+    RCLCPP_INFO_STREAM(node_->get_logger(),
+                       "[MobileManipulatorTarget] enableDualEeTarget = "
+                           << std::boolalpha << enableDualEeTarget_);
+  }
+
+ private:
+  void createMarkers() {
+    auto rightMarker = make6DofMarker("world", "right_ee_target", rightPose_);
+    interactiveMarkerServer_.insert(
+        rightMarker,
+        std::bind(&DualEeTargetNode::processRightFeedback, this,
+                  std::placeholders::_1));
+
+    if (enableDualEeTarget_) {
+      auto leftMarker = make6DofMarker("world", "left_ee_target", leftPose_);
+      interactiveMarkerServer_.insert(
+          leftMarker,
+          std::bind(&DualEeTargetNode::processLeftFeedback, this,
+                    std::placeholders::_1));
+    }
+  }
+
+  void processRightFeedback(
+      const visualization_msgs::msg::InteractiveMarkerFeedback::ConstSharedPtr&
+          feedback) {
+    if (feedback->event_type ==
+        visualization_msgs::msg::InteractiveMarkerFeedback::POSE_UPDATE) {
+      rightPose_ = feedback->pose;
+      publishTargetTrajectories();
+    }
+  }
+
+  void processLeftFeedback(
+      const visualization_msgs::msg::InteractiveMarkerFeedback::ConstSharedPtr&
+          feedback) {
+    if (feedback->event_type ==
+        visualization_msgs::msg::InteractiveMarkerFeedback::POSE_UPDATE) {
+      leftPose_ = feedback->pose;
+      publishTargetTrajectories();
+    }
+  }
+
+  void observationCallback(
+      const ocs2_msgs::msg::MpcObservation::ConstSharedPtr& msg) {
+    {
+      std::lock_guard<std::mutex> lock(latestObservationMutex_);
+      latestObservation_ = ros_msg_conversions::readObservationMsg(*msg);
+      hasObservation_ = true;
+    }
+
+    // Publish once when first observation arrives, so OCP has a valid target
+    // immediately.
+    if (!publishedInitialTarget_) {
+      publishedInitialTarget_ = true;
+      publishTargetTrajectories();
+    }
+  }
+
+  TargetTrajectories buildSingleTarget(
+      const SystemObservation& observation) const {
+    const scalar_array_t timeTrajectory{observation.time};
+
+    const Eigen::Vector3d position(rightPose_.position.x, rightPose_.position.y,
+                                   rightPose_.position.z);
+    Eigen::Quaterniond orientation(
+        rightPose_.orientation.w, rightPose_.orientation.x,
+        rightPose_.orientation.y, rightPose_.orientation.z);
+    orientation.normalize();
+
+    const vector_t target = (vector_t(7) << position, orientation.coeffs()).finished();
+    const vector_array_t stateTrajectory{target};
+    const vector_array_t inputTrajectory{
+        vector_t::Zero(observation.input.size())};
+
+    return {timeTrajectory, stateTrajectory, inputTrajectory};
+  }
+
+  TargetTrajectories buildDualTarget(
+      const SystemObservation& observation) const {
+    const scalar_array_t timeTrajectory{observation.time};
+
+    const Eigen::Vector3d rightPosition(rightPose_.position.x,
+                                        rightPose_.position.y,
+                                        rightPose_.position.z);
+    Eigen::Quaterniond rightOrientation(
+        rightPose_.orientation.w, rightPose_.orientation.x,
+        rightPose_.orientation.y, rightPose_.orientation.z);
+    rightOrientation.normalize();
+
+    const Eigen::Vector3d leftPosition(leftPose_.position.x, leftPose_.position.y,
+                                       leftPose_.position.z);
+    Eigen::Quaterniond leftOrientation(
+        leftPose_.orientation.w, leftPose_.orientation.x,
+        leftPose_.orientation.y, leftPose_.orientation.z);
+    leftOrientation.normalize();
+
+    vector_t target(14);
+    target << rightPosition, rightOrientation.coeffs(), leftPosition, leftOrientation.coeffs();
+
+    const vector_array_t stateTrajectory{target};
+    const vector_array_t inputTrajectory{
+        vector_t::Zero(observation.input.size())};
+
+    return {timeTrajectory, stateTrajectory, inputTrajectory};
+  }
+
+  void publishTargetTrajectories() {
+    if (!hasObservation_) {
+      return;
+    }
+
+    SystemObservation observation;
+    {
+      std::lock_guard<std::mutex> lock(latestObservationMutex_);
+      observation = latestObservation_;
+    }
+
+    const auto targetTrajectories =
+        enableDualEeTarget_ ? buildDualTarget(observation)
+                            : buildSingleTarget(observation);
+    targetTrajectoriesPublisher_.publishTargetTrajectories(targetTrajectories);
+  }
+
+ private:
+  rclcpp::Node::SharedPtr node_;
+  std::string robotName_;
+
+  bool enableDualEeTarget_ = false;
+  bool hasObservation_ = false;
+  bool publishedInitialTarget_ = false;
+
+  geometry_msgs::msg::Pose rightPose_;
+  geometry_msgs::msg::Pose leftPose_;
+
+  std::mutex latestObservationMutex_;
+  SystemObservation latestObservation_;
+
+  rclcpp::Subscription<ocs2_msgs::msg::MpcObservation>::SharedPtr
+      observationSubscriber_;
+
+  interactive_markers::InteractiveMarkerServer interactiveMarkerServer_;
+  TargetTrajectoriesRosPublisher targetTrajectoriesPublisher_;
+};
