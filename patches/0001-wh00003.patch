+void MobileManipulatorDummyVisualization::publishTargetTrajectories(
+    const ros::Time& timeStamp, const TargetTrajectories& targetTrajectories) {
+  const auto& target = targetTrajectories.stateTrajectory.back();
+
+  Eigen::Vector3d rightPos = target.segment<3>(0);
+  Eigen::Quaterniond rightQuat;
+  rightQuat.coeffs() = target.segment<4>(3);
+
+  geometry_msgs::TransformStamped right_tf;
+  right_tf.header.stamp = timeStamp;
+  right_tf.header.frame_id = "world";
+  right_tf.child_frame_id = "command_right";
+  right_tf.transform.translation = ros_msg_helpers::getVectorMsg(rightPos);
+  right_tf.transform.rotation = ros_msg_helpers::getOrientationMsg(rightQuat);
+  tfBroadcaster_.sendTransform(right_tf);
+
+  if (enableDualEeTarget_) {
+    Eigen::Vector3d leftPos = target.segment<3>(7);
+    Eigen::Quaterniond leftQuat;
+    leftQuat.coeffs() = target.segment<4>(10);
+
+    geometry_msgs::TransformStamped left_tf;
+    left_tf.header.stamp = timeStamp;
+    left_tf.header.frame_id = "world";
+    left_tf.child_frame_id = "command_left";
+    left_tf.transform.translation = ros_msg_helpers::getVectorMsg(leftPos);
+    left_tf.transform.rotation = ros_msg_helpers::getOrientationMsg(leftQuat);
+    tfBroadcaster_.sendTransform(left_tf);
+  }
 }
 
