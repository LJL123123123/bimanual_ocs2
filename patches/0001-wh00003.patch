+
+      (0,0)  5.0  ; SH_ROT velocity
+      (1,1)  5.0  ; SH_FLE velocity
+      (2,2)  5.0  ; EL_FLE velocity
+      (3,3)  5.0  ; EL_ROT velocity
+      (4,4)  5.0  ; WR_FLE velocity
